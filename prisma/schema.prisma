generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum PostStatus {
  DRAFT
  PUBLISHED
}

enum ReactionType {
  LIKE
  FIRE
  CLAP
}

enum ActivityType {
  FOLLOW
  PUBLISH_POST
  COMMENT
  REACTION
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  username     String    @unique
  passwordHash String
  role         Role      @default(USER)
  bio          String?
  avatarUrl    String?
  website      String?

  posts        Post[]
  comments     Comment[]
  bookmarks    Bookmark[]
  reactions    Reaction[]
  stories      Story[]

  followers    Follow[]  @relation("following")
  following    Follow[]  @relation("follower")

  notifications      Notification[] @relation("NotificationUser")
  actorNotifications Notification[] @relation("NotificationActor")
  activities         Activity[]
  mentionedIn        Notification[] @relation("mentionedUser")

  resetToken       String?
  resetTokenExpiry DateTime?

  createdAt    DateTime  @default(now())
}

model Post {
  id          String     @id @default(uuid())
  title       String
  slug        String     @unique
  content     String
  excerpt     String?
  coverImage  String?
  views       Int        @default(0)
  isFeatured  Boolean    @default(false)
  featuredOrder Int      @default(0)

  analytics   PostAnalytics[]
  views_log   PostView[]

  status      PostStatus @default(DRAFT)

  authorId    String
  author      User       @relation(fields: [authorId], references: [id])

  categoryId  String?
  category    Category?  @relation(fields: [categoryId], references: [id])

  comments    Comment[]
  tags        PostTag[]
  bookmarks   Bookmark[]
  reactions   Reaction[]
  slides      Slide[]

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  publishedAt DateTime?

  @@index([authorId])
  @@index([categoryId])
  @@index([slug])
  @@index([views])
  @@index([isFeatured, featuredOrder])
}

model Comment {
  id        String    @id @default(uuid())
  content   String

  postId    String
  post      Post      @relation(fields: [postId], references: [id])

  authorId  String
  author    User      @relation(fields: [authorId], references: [id])

  parentId  String?
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies   Comment[] @relation("CommentReplies")

  createdAt DateTime  @default(now())

  @@index([postId])
}

model Category {
  id          String  @id @default(uuid())
  name        String
  slug        String  @unique
  description String?

  posts       Post[]

  @@index([slug])
}

model Tag {
  id    String    @id @default(uuid())
  name  String
  slug  String    @unique

  posts PostTag[]

  @@index([slug])
}

model PostTag {
  postId String
  tagId  String

  post Post @relation(fields: [postId], references: [id])
  tag  Tag  @relation(fields: [tagId], references: [id])

  @@id([postId, tagId])
}

model Bookmark {
  id        String   @id @default(uuid())
  userId    String
  postId    String

  user      User     @relation(fields: [userId], references: [id])
  post      Post     @relation(fields: [postId], references: [id])

  createdAt DateTime @default(now())

  @@unique([userId, postId])
  @@index([userId])
  @@index([postId])
}

model Reaction {
  id        String       @id @default(uuid())
  type      ReactionType
  userId    String
  postId    String

  user      User         @relation(fields: [userId], references: [id])
  post      Post         @relation(fields: [postId], references: [id])

  createdAt DateTime     @default(now())

  @@unique([userId, postId, type])
  @@index([postId])
  @@index([userId])
}

model Subscriber {
  id        String   @id @default(uuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model PostView {
  id          String   @id @default(uuid())
  postId      String
  visitorHash String
  referrer    String?
  userAgent   String?

  post        Post     @relation(fields: [postId], references: [id])

  createdAt   DateTime @default(now())

  @@index([postId])
  @@index([visitorHash])
  @@index([createdAt])
}

model PostAnalytics {
  id             String   @id @default(uuid())
  date           DateTime
  postId         String
  views          Int      @default(0)
  uniqueVisitors Int      @default(0)
  comments       Int      @default(0)
  reactions      Int      @default(0)

  post           Post     @relation(fields: [postId], references: [id])

  @@unique([postId, date])
  @@index([postId])
  @@index([date])
}

model Follow {
  id          String   @id @default(uuid())
  followerId  String
  followingId String

  follower    User     @relation("follower", fields: [followerId], references: [id])
  following   User     @relation("following", fields: [followingId], references: [id])

  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

enum NotifType {
  FOLLOW
  COMMENT
  REACTION
  MENTION
  PUBLISH
}

model Notification {
  id        String    @id @default(uuid())
  type      NotifType
  message   String
  link      String?
  read      Boolean   @default(false)

  userId    String
  user      User      @relation("NotificationUser", fields: [userId], references: [id], onDelete: Cascade)

  actorId   String?
  actor     User?     @relation("NotificationActor", fields: [actorId], references: [id])

  postId    String?
  mentionId String?

  mentionedUser User? @relation("mentionedUser", fields: [mentionId], references: [id])

  createdAt DateTime  @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
}

model Activity {
  id        String       @id @default(uuid())
  type      ActivityType
  message   String
  link      String?

  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime     @default(now())

  @@index([userId, createdAt])
}

model Story {
  id          String    @id @default(uuid())
  title       String
  imageUrl    String
  linkUrl     String?
  authorId    String
  author      User      @relation(fields: [authorId], references: [id])
  active      Boolean   @default(true)
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  expiresAt   DateTime?

  @@index([active, order])
}

model Slide {
  id          String    @id @default(uuid())
  title       String
  subtitle    String?
  imageUrl    String
  linkUrl     String?
  postId      String?
  post        Post?     @relation(fields: [postId], references: [id])
  active      Boolean   @default(true)
  order       Int       @default(0)
  createdAt   DateTime  @default(now())

  @@index([active, order])
}

model Setting {
  key        String   @id
  value      String
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())
}

model Theme {
  id        String   @id @default(uuid())
  name      String   @unique
  directory String
  version   String
  author    String
  description String
  status    String   @default("inactive")
  config    String   @default("{}")
  installedAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
